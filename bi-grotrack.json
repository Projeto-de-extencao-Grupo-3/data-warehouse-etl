      "panel-1": {
        "kind": "Panel",
        "spec": {
          "id": 1,
          "title": "Histórico de Serviços",
          "description": "Nesta tabela exibe todos os serviços que passaram pela oficina no ano e mês selecionado",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "mysql",
                      "version": "v0",
                      "datasource": {
                        "name": "afl02y4af6a68e"
                      },
                      "spec": {
                        "dataset": "grotrack",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT \n    o.id_ordem_servico id,\n    CONCAT('R$', IFNULL(o.valor_total,0)) total,\n    CONCAT('R$', IFNULL(o.valor_total_servicos,0)) total_servico,\n    CONCAT('R$', IFNULL(o.valor_total_produtos,0)) total_produto,\n    IFNULL(DATE_FORMAT(e.data_entrada_prevista, '%d/%m/%Y'), 'DATA NÃO DEFINIDA') data_entrada_prevista,\n    IFNULL(DATE_FORMAT(e.data_entrada_efetiva, '%d/%m/%Y'), 'AGUARDANDO VEICULO') data_entrada_efetiva,\n    IFNULL(DATE_FORMAT(o.data_saida_prevista, '%d/%m/%Y'), 'DATA NÃO DEFINIDA') data_saida_prevista,\n    IFNULL(DATE_FORMAT(o.data_saida_efetiva, '%d/%m/%Y'), 'AGUARDANDO FINALIZAÇÃO') data_saida_efetiva,\n    o.status status_servico,\n    CASE\n        WHEN o.pagt_realizado = 1 THEN 'REALIZADO'\n        ELSE 'PENDENTE'\n    END as status_pagamento,    \n    CASE\n        WHEN o.nf_realizada = 1 THEN 'EMITIDA'\n        ELSE 'PENDENTE'\n    END as status_nota_fiscal\nFROM grotrack.ordem_de_servicos o\nJOIN grotrack.registro_entrada e ON e.fk_ordem_servico = o.id_ordem_servico\nWHERE MONTH(e.data_entrada_efetiva) IN ($mes)\n  AND YEAR(e.data_entrada_efetiva) IN ($ano)\n  AND o.status NOT IN ('CANCELADO');",
                        "sql": {
                          "columns": [
                            {
                              "name": "SUM",
                              "parameters": [
                                {
                                  "name": "valor_total",
                                  "type": "functionParameter"
                                }
                              ],
                              "type": "function"
                            }
                          ],
                          "groupBy": [
                            {
                              "property": {
                                "name": "data_saida_efetiva",
                                "type": "string"
                              },
                              "type": "groupBy"
                            }
                          ],
                          "limit": 50
                        },
                        "table": "ordem_de_servicos"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
