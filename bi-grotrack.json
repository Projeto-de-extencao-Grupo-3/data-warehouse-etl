      "panel-7": {
        "kind": "Panel",
        "spec": {
          "id": 7,
          "title": "Mediana de Duração por Tipo de Serviço",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "mysql",
                      "version": "v0",
                      "datasource": {
                        "name": "afl02y4af6a68e"
                      },
                      "spec": {
                        "dataset": "grotrack",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT \n    tipo_servico, \n    AVG(dias_servico) AS mediana_dias\nFROM (\n    SELECT \n        s.tipo_servico, \n        DATEDIFF(os.data_saida_efetiva, re.data_entrada_efetiva) AS dias_servico,\n        ROW_NUMBER() OVER (PARTITION BY s.tipo_servico ORDER BY DATEDIFF(os.data_saida_efetiva, re.data_entrada_efetiva)) AS rn,\n        COUNT(*) OVER (PARTITION BY s.tipo_servico) AS total_count\n    FROM grotrack.ordem_de_servicos os\n    JOIN grotrack.itens_servicos s ON s.fk_ordem_servico = os.id_ordem_servico\n    JOIN grotrack.registro_entrada re ON re.fk_ordem_servico = os.id_ordem_servico\n    WHERE os.data_saida_efetiva IS NOT NULL \n      AND re.data_entrada_efetiva IS NOT NULL\n      AND MONTH(re.data_entrada_efetiva) IN ($mes) \n    AND YEAR(re.data_entrada_efetiva) IN ($ano) \n    AND os.status = 'FINALIZADO' \n\n) AS subquery\nWHERE rn IN (FLOOR((total_count + 1) / 2), CEIL((total_count + 1) / 2))\nGROUP BY tipo_servico\nORDER BY mediana_dias DESC\nLIMIT 5;",
                        "sql": {
                          "columns": [
                            {
                              "parameters": [],
                              "type": "function"
                            }
                          ],
                          "groupBy": [
                            {
                              "property": {
                                "type": "string"
                              },
                              "type": "groupBy"
                            }
                          ],
                          "limit": 50
                        }
                      }
                    },
