      "panel-6": {
        "kind": "Panel",
        "spec": {
          "id": 6,
          "title": "Faturamento por Tipo de Serviço",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "mysql",
                      "version": "v0",
                      "datasource": {
                        "name": "afl02y4af6a68e"
                      },
                      "spec": {
                        "dataset": "grotrack",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT \n    s.tipo_servico tipo_servico,\n    SUM(os.valor_total_servicos) AS faturamento\nFROM grotrack.ordem_de_servicos os\nJOIN grotrack.itens_servicos s ON s.fk_ordem_servico = os.id_ordem_servico\nJOIN grotrack.registro_entrada re ON re.fk_ordem_servico = os.id_ordem_servico\nWHERE MONTH(re.data_entrada_efetiva) IN ($mes) \nAND YEAR(re.data_entrada_efetiva) IN ($ano) \nAND os.status = 'FINALIZADO' \nGROUP BY s.tipo_servico\nORDER BY faturamento DESC;",
                        "sql": {
                          "columns": [
                            {
                              "parameters": [],
                              "type": "function"
                            }
                          ],
